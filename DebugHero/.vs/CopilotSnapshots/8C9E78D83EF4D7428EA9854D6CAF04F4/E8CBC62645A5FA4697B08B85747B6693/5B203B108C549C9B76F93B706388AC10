        public int BerekenDebugHeroWachttijd(string sensorXmlPath)
        {
            int wachttijd = 0;
            XmlDocument doc = new XmlDocument();
            doc.Load(sensorXmlPath);
            // 12 sensoren: Sensor01 t/m Sensor12
            for (int i = 1; i <= 12; i++)
            {
                string sensorNaam = $"Sensor{(i < 10 ? "0" : "")}{i}";
                var node = doc.SelectSingleNode($"//{sensorNaam}");
                if (node != null && node.InnerText.Trim().ToLower() == "true")
                {
                    if (i == 1 || i == 2)
                        wachttijd += 6;
                    else
                        wachttijd += 4;
                }
            }
            return wachttijd;
        }

        public enum KarStatus { Actief, InOnderhoud, NietActief }

        public KarStatus[] DebugHeroKarren = new KarStatus[3] { KarStatus.Actief, KarStatus.Actief, KarStatus.Actief };

        public void ZetKarInOnderhoud(int karIndex)
        {
            if (karIndex >= 0 && karIndex < DebugHeroKarren.Length)
                DebugHeroKarren[karIndex] = KarStatus.InOnderhoud;
        }

        public void ZetKarActief(int karIndex)
        {
            if (karIndex >= 0 && karIndex < DebugHeroKarren.Length)
                DebugHeroKarren[karIndex] = KarStatus.Actief;
        }

        private void UpdateBtn_Click(object sender, RoutedEventArgs e)
        {
            // Pad naar sensordata XML (pas aan indien nodig)
            string sensorXmlPath = "Assets/SensorData/WachtrijSensoren.xml";
            int wachttijd = BerekenDebugHeroWachttijd(sensorXmlPath);
            WachttijdLabel.Text = $"{wachttijd} minuten";
            UpdateKarStatusLabels();
        }

        private void Kar1OnderhoudBtn_Click(object sender, RoutedEventArgs e)
        {
            ZetKarInOnderhoud(0);
            UpdateKarStatusLabels();
        }

        private void Kar2OnderhoudBtn_Click(object sender, RoutedEventArgs e)
        {
            ZetKarInOnderhoud(1);
            UpdateKarStatusLabels();
        }

        private void Kar3OnderhoudBtn_Click(object sender, RoutedEventArgs e)
        {
            ZetKarInOnderhoud(2);
            UpdateKarStatusLabels();
        }

        private void UpdateKarStatusLabels()
        {
            Kar1StatusLabel.Text = DebugHeroKarren[0] == KarStatus.InOnderhoud ? "In onderhoud" : "Actief";
            Kar2StatusLabel.Text = DebugHeroKarren[1] == KarStatus.InOnderhoud ? "In onderhoud" : "Actief";
            Kar3StatusLabel.Text = DebugHeroKarren[2] == KarStatus.InOnderhoud ? "In onderhoud" : "Actief";
        }

        // UI controls
        private TextBlock WachttijdLabel => (TextBlock)FindName("WachttijdLabel");
        private TextBlock Kar1StatusLabel => (TextBlock)FindName("Kar1StatusLabel");
        private TextBlock Kar2StatusLabel => (TextBlock)FindName("Kar2StatusLabel");
        private TextBlock Kar3StatusLabel => (TextBlock)FindName("Kar3StatusLabel");
    }
