<Window x:Class="DeveloperLand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeveloperLand"
        mc:Ignorable="d"
        Title="Debug Hero" Height="500" Width="900" Background="#FFD600">
    <Grid>
        <TextBlock Text="Debug Hero" FontSize="40" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        <Border Background="#FFEB3B" CornerRadius="10" Padding="20" Margin="50,80,50,0" Height="120" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Geschatte wachttijd:" FontSize="22" Foreground="#1976D2"/>
                <TextBlock x:Name="WachttijdLabel" Text="0 minuten" FontSize="32" FontWeight="Bold" Foreground="#D32F2F"/>
            </StackPanel>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,220,0,0">
            <Border Background="#00E676" CornerRadius="8" Padding="10" Margin="10">
                <StackPanel>
                    <TextBlock Text="Kar 1" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="Kar1StatusLabel" Text="Actief" FontSize="16" Foreground="#D32F2F"/>
                    <Button x:Name="Kar1OnderhoudBtn" Content="Zet in onderhoud" Click="Kar1OnderhoudBtn_Click" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#00B0FF" CornerRadius="8" Padding="10" Margin="10">
                <StackPanel>
                    <TextBlock Text="Kar 2" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="Kar2StatusLabel" Text="Actief" FontSize="16" Foreground="#D32F2F"/>
                    <Button x:Name="Kar2OnderhoudBtn" Content="Zet in onderhoud" Click="Kar2OnderhoudBtn_Click" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="#FF4081" CornerRadius="8" Padding="10" Margin="10">
                <StackPanel>
                    <TextBlock Text="Kar 3" FontSize="18" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock x:Name="Kar3StatusLabel" Text="Actief" FontSize="16" Foreground="#D32F2F"/>
                    <Button x:Name="Kar3OnderhoudBtn" Content="Zet in onderhoud" Click="Kar3OnderhoudBtn_Click" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
        <Button x:Name="UpdateBtn" Content="Update informatie" FontSize="20" Background="#1976D2" Foreground="White" HorizontalAlignment="Center" Margin="0,370,0,0" Width="250" Height="50" Click="UpdateBtn_Click"/>
    </Grid>
</Window>
